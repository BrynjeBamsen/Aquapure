# Stripe TEST-noegle (starter med sk_test_...). Hent i Stripe Dashboard med "Test mode" slaaet til.
# (Placeholder skrevet saa GitHub secret scanning ikke fejlagtigt blokerer commits.)
STRIPE_SECRET_KEY=indsaet_din_stripe_testnoegle_her

# Valgfrit: kun noedvendigt hvis du saetter en Stripe-webhook op mod /webhook
STRIPE_WEBHOOK_SECRET=indsaet_din_webhook_secret_her

# Supabase (brugerkonti + abonnementsadministration) - valgfrit, gaestekoeb virker uden
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=indsaet_anon_key_her
SUPABASE_SERVICE_ROLE_KEY=indsaet_service_role_key_her
